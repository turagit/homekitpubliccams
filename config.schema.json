{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HomeKit Public Cams Configuration",
  "type": "object",
  "properties": {
    "provider": {
      "title": "Source provider",
      "description": "Select the backend service used to source camera media.",
      "type": "string",
      "enum": ["nasa-api", "nasa-library", "curated-feed"],
      "oneOf": [
        { "const": "nasa-api", "title": "NASA API" },
        { "const": "nasa-library", "title": "NASA Image/Video Library" },
        { "const": "curated-feed", "title": "Curated Feed" }
      ]
    },
    "presetId": {
      "title": "Feed preset",
      "description": "Select a provider-specific preset feed.",
      "type": "string"
    }
  },
  "required": ["provider", "presetId"],
  "allOf": [
    {
      "if": {
        "properties": {
          "provider": { "const": "nasa-api" }
        },
        "required": ["provider"]
      },
      "then": {
        "properties": {
          "presetId": {
            "enum": ["curiosity-latest", "perseverance-latest", "apod"],
            "oneOf": [
              { "const": "curiosity-latest", "title": "Curiosity (Latest)" },
              { "const": "perseverance-latest", "title": "Perseverance (Latest)" },
              { "const": "apod", "title": "Astronomy Picture of the Day" }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "provider": { "const": "nasa-library" }
        },
        "required": ["provider"]
      },
      "then": {
        "properties": {
          "presetId": {
            "enum": ["jwst-featured", "hubble-featured"],
            "oneOf": [
              { "const": "jwst-featured", "title": "JWST Featured" },
              { "const": "hubble-featured", "title": "Hubble Featured" }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "provider": { "const": "curated-feed" }
        },
        "required": ["provider"]
      },
      "then": {
        "properties": {
          "presetId": {
            "enum": ["nasa-mixed"],
            "oneOf": [
              { "const": "nasa-mixed", "title": "NASA Mixed Feed" }
            ]
          }
        }
      }
    }
  ]
}
